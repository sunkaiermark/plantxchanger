{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "default": "PlantXchange",
      "required": true
    },
    "contactEmail": {
      "type": "email",
      "required": true
    },
    "whatsappNumber": {
      "type": "string",
      "required": true
    },
    "whatsappDisplayLabel": {
      "type": "string",
      "default": "WhatsApp"
    },
    "defaultSeoTitle": {
      "type": "string"
    },
    "defaultSeoDescription": {
      "type": "text"
    },
    "footerSummary": {
      "type": "text"
    }
  }
}
