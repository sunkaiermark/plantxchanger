{
  "kind": "collectionType",
  "collectionName": "inquiries",
  "info": {
    "singularName": "inquiry",
    "pluralName": "inquiries",
    "displayName": "Inquiry"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "inquiryType": {
      "type": "enumeration",
      "enum": ["buyer", "seller"],
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "responded", "negotiating", "accepted"],
      "default": "pending",
      "required": true
    },
    "relatedEquipment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::equipment.equipment"
    },
    "equipmentReferenceSnapshot": {
      "type": "string"
    },
    "equipmentTitleSnapshot": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "required": true
    },
    "company": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "string"
    },
    "whatsapp": {
      "type": "string"
    },
    "country": {
      "type": "string"
    },
    "message": {
      "type": "text",
      "required": true
    },
    "sourcePage": {
      "type": "string"
    },
    "utmSource": {
      "type": "string"
    },
    "utmMedium": {
      "type": "string"
    },
    "utmCampaign": {
      "type": "string"
    },
    "userAgent": {
      "type": "text"
    },
    "ipAddress": {
      "type": "string"
    }
  }
}
